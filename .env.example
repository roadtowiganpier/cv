# Copy this file to .env and fill in your values
# NEVER commit .env to git

# Ghost URL - update when subdomain is live
GHOST_URL=http://YOUR_VPS_IP/blog

# MySQL credentials - choose strong passwords
MYSQL_ROOT_PASSWORD=change_me_root
MYSQL_DATABASE=ghost
MYSQL_USER=ghost
MYSQL_PASSWORD=change_me_ghost

# Mail (optional - configure when ready)
MAIL_HOST=localhost
MAIL_PORT=25
